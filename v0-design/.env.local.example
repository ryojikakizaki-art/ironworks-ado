# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Embedded Checkout で必要 (loadStripe 初期化用、クライアントに公開される公開鍵)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Calendar (optional - for production schedule tracking)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# Resend (contact form emails)
RESEND_API_KEY=re_...
CONTACT_TO_EMAIL=your-inbox@example.com
CONTACT_FROM=IRONWORKS ado <noreply@tantetuzest.com>

# Google Analytics 4 (GA4) 測定 ID
# GA4 プロパティ > 管理 > データストリーム > 該当ストリームの「測定 ID」(G-で始まる文字列)
# ⚠️ 本番に設定する際は実在するプロパティの ID を使うこと（プレースホルダのまま入れると計測されない）
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google 広告 変換 ID — 例: AW-11473401014
NEXT_PUBLIC_ADS_ID=AW-XXXXXXXXXX

# Google 広告「お問い合わせ送信」用 CV ラベル
# (Google広告 > 目標 > コンバージョン > 新規アクションで「お問い合わせ」を作成し、
#  gtag の send_to 末尾部分 (AW-xxx/[ここ]) をコピーして貼り付け)
NEXT_PUBLIC_ADS_CONTACT_CV_LABEL=
